schemas: (auto-generated from contract)
  api-version:
    - api_version: integer
    - contract_version: string
    - crate_version: string
  capabilities:
    - api_version: integer
    - connectors: array
    - contract_version: string
    - crate_version: string
    - features: array
    - limits: object
      - max_agg_buckets: integer
      - max_content_length: integer
      - max_fields: integer
      - max_limit: integer
  diag:
    - connectors: array
    - database: object
      - conversations: integer
      - exists: boolean
      - messages: integer
      - size_bytes: integer
    - index: object
      - exists: boolean
      - size_bytes: integer
    - paths: object
      - data_dir: string
      - db_path: string
      - index_path: string
    - platform: object
      - arch: string
      - os: string
    - version: string
  health:
    - errors: array
    - explanation: ?
    - healthy: boolean
    - initialized: boolean
    - latency_ms: integer
    - parallel_wal_shadow: object
      - active: boolean
      - chunk_errors: integer
      - chunks_observed: integer
      - cumulative_wall_micros: integer
      - recent_chunks: array
    - recommended_action: ?
    - responsiveness: object
      - current_capacity_pct: integer
      - disabled_via_env: boolean
      - grow_count: integer
      - healthy_streak: integer
      - last_reason: ?
      - last_snapshot: ?
        - load_per_core: ?
        - psi_cpu_some_avg10: ?
      - recent_decisions: array
      - shrink_count: integer
      - ticks_total: integer
    - state: object
      - _meta: object
        - data_dir: string
        - db_path: string
        - timestamp: string
      - database: object
        - conversations: integer
        - exists: boolean
        - messages: integer
      - index: object
        - age_seconds: ?
        - exists: boolean
        - fresh: boolean
        - last_indexed_at: ?
        - stale: boolean
        - stale_threshold_seconds: integer
      - pending: object
        - sessions: integer
        - watch_active: ?
    - status: string
  index:
    - conversations: ?
    - data_dir: ?
    - db_path: ?
    - elapsed_ms: integer
    - error: ?
    - force_rebuild: ?
    - full: ?
    - messages: ?
    - success: boolean
  introspect:
    - api_version: integer
    - commands: array
    - contract_version: string
    - global_flags: array
    - response_schemas: object
  search:
    - _meta: object
      - cache_stats: object
        - hits: integer
        - misses: integer
        - shortfall: integer
      - elapsed_ms: integer
      - hits_clamped: boolean
      - index_freshness: object
        - age_seconds: ?
        - fresh: boolean
        - last_indexed_at: ?
        - pending_sessions: integer
        - stale: boolean
      - max_tokens: ?
      - next_cursor: ?
      - request_id: ?
      - state: object
        - database: object
        - index: object
      - tokens_estimated: ?
      - wildcard_fallback: boolean
    - _warning: ?
    - aggregations: ?
    - count: integer
    - cursor: ?
    - hits: array
    - hits_clamped: boolean
    - limit: integer
    - max_tokens: ?
    - offset: integer
    - query: string
    - request_id: ?
    - total_matches: integer
  sessions:
    - sessions: array
  state:
    - _meta: object
      - data_dir: string
      - db_path: string
      - timestamp: string
    - database: object
      - conversations: integer
      - exists: boolean
      - messages: integer
      - path: string
    - explanation: ?
    - healthy: boolean
    - index: object
      - age_seconds: ?
      - exists: boolean
      - fresh: boolean
      - last_indexed_at: ?
      - stale: boolean
      - stale_threshold_seconds: integer
    - initialized: boolean
    - pending: object
      - sessions: integer
      - watch_active: ?
    - recommended_action: ?
    - status: string
  stats:
    - by_agent: array
    - conversations: integer
    - date_range: object
      - newest: ?
      - oldest: ?
    - db_path: string
    - messages: integer
    - top_workspaces: array
  status:
    - _meta: object
      - data_dir: string
      - db_path: string
      - timestamp: string
    - database: object
      - conversations: integer
      - exists: boolean
      - messages: integer
      - path: string
    - explanation: ?
    - healthy: boolean
    - index: object
      - age_seconds: ?
      - exists: boolean
      - fresh: boolean
      - last_indexed_at: ?
      - stale: boolean
      - stale_threshold_seconds: integer
    - initialized: boolean
    - pending: object
      - sessions: integer
      - watch_active: ?
    - recommended_action: ?
    - status: string
  view:
    - end_line: integer
    - highlight_line: ?
    - lines: array
    - path: string
    - start_line: integer
